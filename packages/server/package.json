{
  "name": "@dynamia-tasks/server",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dynamia-server": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && pnpm bundle",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --target=node20 --outfile=dist/cli.bundle.js --external:fsevents",
    "dev": "tsx src/cli.ts --cwd ${DYNAMIA_PROJECT_PATH:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@dynamia-tasks/connector-github": "workspace:*",
    "@dynamia-tasks/connector-local": "workspace:*",
    "@dynamia-tasks/core": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.10.2",
    "typescript": "^5.4.5"
  }
}
